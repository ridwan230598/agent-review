{
  "name": "@review-agent/review-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "review-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@review-agent/review-convex-bridge": "workspace:*",
    "@review-agent/review-core": "workspace:*",
    "@review-agent/review-provider-codex": "workspace:*",
    "@review-agent/review-provider-openai": "workspace:*",
    "@review-agent/review-types": "workspace:*",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "tsx": "^4.20.5"
  }
}
